# Database - PostgreSQL
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/ride_db

# JWT
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=60

# OTP (dev: qualquer valor)
OTP_SECRET=your-otp-secret
OTP_EXPIRATION_MINUTES=5

# Stripe (modo teste: sk_test_... e pk_test_...)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_MOCK=true - skip Stripe API (simulator/testing only)

# Ambiente: dev | production
ENV=dev

# Testes / simulador (seed, /dev/seed-simulator)
# ENABLE_DEV_TOOLS=true

# Login com telemovel (BETA)
# BETA_MODE=true
