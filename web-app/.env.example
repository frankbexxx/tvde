# Base URL for API (default: /api for dev proxy)
VITE_API_URL=/api

# Sentry (opcional) - error tracking em preview/production.
# So activa se a var estiver preenchida E MODE != 'development'.
# DSN obtido em https://francisco-bexiga.sentry.io (projecto javascript-react).
VITE_SENTRY_DSN=

# Sentry release (opcional) - geralmente preenchido pelo pipeline de CI/deploy
# com o SHA curto do commit (ex.: git rev-parse --short HEAD).
VITE_SENTRY_RELEASE=
