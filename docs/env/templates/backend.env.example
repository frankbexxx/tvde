# Backend env template (copy → backend/.env locally)
# Nunca commitar backend/.env. Este ficheiro é seguro (sem secrets reais).

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ride_db

JWT_SECRET_KEY=dev-jwt-secret-key-at-least-32-characters-long
OTP_SECRET=dev-otp-secret-key-at-least-32-characters-long

# dev | production (ou usa ENVIRONMENT)
ENV=dev
# ENVIRONMENT=production

# Seed/tokens em ambiente não-prod (ou explicitamente quando precisares)
ENABLE_DEV_TOOLS=true

# Produção: lista explícita (vírgulas; sem *)
CORS_ALLOWED_ORIGINS=https://tvde-app-j51f.onrender.com,http://localhost:5173

# Stripe — regra “mock por defeito”
STRIPE_MOCK=true
# Só preencher quando STRIPE_MOCK=false:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

