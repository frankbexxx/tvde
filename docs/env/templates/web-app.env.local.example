# Web App env template (copy → web-app/.env.local locally)
# Nunca commitar web-app/.env.local (pode conter keys).

# Default dev: proxy /api no Vite para http://localhost:8000
VITE_API_URL=/api

# Flags UX (opcionais)
VITE_DRIVER_BOTTOM_NAV=true
VITE_DRIVER_HOME_TWO_STEP=true

# Mapas (opcional, mas recomendado para mapa/geocoding)
# VITE_MAPTILER_KEY=...

# Observabilidade (opcional)
# VITE_SENTRY_DSN=...
# VITE_SENTRY_RELEASE=...

# Stripe (frontend) — regra “mock por defeito”
VITE_STRIPE_MOCK=true
# Só preencher quando VITE_STRIPE_MOCK=false:
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

